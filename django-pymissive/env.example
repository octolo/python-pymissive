# =============================================================================
# Django Missive - Variables d'environnement
# =============================================================================
# Copiez ce fichier en .env et remplissez vos clés API

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# =============================================================================
# Providers Email
# =============================================================================

# SendGrid
SENDGRID_API_KEY=

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Amazon SES
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# =============================================================================
# Providers SMS
# =============================================================================

# Twilio (SMS + WhatsApp + Vocal)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Vonage (ex-Nexmo)
VONAGE_API_KEY=
VONAGE_API_SECRET=
VONAGE_PHONE_NUMBER=

# SMSPartner (VoicePartner API)
SMSPARTNER_API_KEY=
SMSPARTNER_SENDER=YourApp

# =============================================================================
# Providers Courrier & LRE
# =============================================================================

# La Poste
LAPOSTE_API_KEY=

# AR24 (LRE)
AR24_API_TOKEN=
AR24_API_URL=https://api.ar24.fr
AR24_SENDER_ID=

# Certeurope (LRE)
CERTEUROPE_API_KEY=
CERTEUROPE_API_SECRET=
CERTEUROPE_API_URL=
CERTEUROPE_SENDER_EMAIL=

# =============================================================================
# Providers Messageries
# =============================================================================

# Telegram
TELEGRAM_BOT_TOKEN=

# Signal
SIGNAL_API_KEY=

# Facebook Messenger
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=

# =============================================================================
# Providers Push Notifications
# =============================================================================

# Firebase Cloud Messaging (Android)
FCM_SERVER_KEY=

# Apple Push Notification (iOS)
APN_CERTIFICATE_PATH=
APN_KEY_ID=
APN_TEAM_ID=

# =============================================================================
# Providers Professionnels
# =============================================================================

# Slack
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Microsoft Teams
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=

# =============================================================================
# Configuration Email par défaut (Django)
# =============================================================================

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@example.com

# =============================================================================
# Ngrok (Development tunnel)
# =============================================================================

# Ngrok authentication token (optional but recommended)
# Get your token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_TOKEN=
