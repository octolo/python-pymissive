# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text eol=lf
*.pyi text eol=lf

# Templates
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Config files
*.toml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf
dev.py text eol=lf
manage.py text eol=lf

# Exclude files from distribution
/tests export-ignore
/htmlcov export-ignore
/.pytest_cache export-ignore
/db.sqlite3 export-ignore
/.coverage export-ignore

